# ─── Required ─────────────────────────────────────────────────
# Get from @BotFather on Telegram
BOT_TOKEN=your_telegram_bot_token_here

# Get from https://dashboard.razorpay.com/app/keys
RAZORPAY_KEY_ID=rzp_live_xxxxxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_key_secret_here

# Set when creating your webhook in Razorpay Dashboard → Settings → Webhooks
# Generate a strong secret: openssl rand -hex 32
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret_here

# ─── Optional ─────────────────────────────────────────────────
# Your public HTTPS server URL (needed for Razorpay callbacks)
# e.g. https://yourapp.railway.app  or  https://yourapp.onrender.com
PUBLIC_URL=https://yourapp.railway.app

# Port for the webhook HTTP server (default: 3000)
WEBHOOK_PORT=3000
